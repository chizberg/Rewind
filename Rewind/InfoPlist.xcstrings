{
  "sourceLanguage": "en",
  "strings": {
    "App needs this access to save images to your library": {
      "extractionState": "manual",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App benötigt diesen Zugriff, um Bilder in deiner Mediathek zu speichern"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "App needs this access to save images to your library"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La app necesita este acceso para guardar imágenes en tu biblioteca"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'app a besoin de cet accès pour enregistrer des images dans votre photothèque"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қолданбаға суреттерді медиатекаңызға сақтау үшін бұл рұқсат қажет"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложению нужен доступ, чтобы сохранять фотографии в вашу медиатеку"
          }
        },
        "sr-Latn": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikaciji je potreban ovaj pristup da bi mogla da sačuva slike u vašu galeriju"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Застосунку потрібен цей доступ, щоб зберігати зображення у вашу медіатеку"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilova rasmlarni kutubxonangizga saqlash uchun ushbu ruxsatga muhtoj"
          }
        }
      }
    },
