    "NSCameraUsageDescription": {
      "comment": "Privacy - Camera Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Kamerazugriff wird benötigt, um Vergleichsfotos aufzunehmen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "Camera access is needed to take comparison photos"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se necesita acceso a la cámara para tomar fotos de comparación"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'accès à l'appareil photo est nécessaire pour prendre des photos de comparaison"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Салыстыру фотоларын түсіру үшін камераға қол жеткізу қажет"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ к камере нужен, чтобы делать фото сравнения"
          }
        },
        "sr-Latn": {
          "stringUnit": {
            "state": "translated",
            "value": "Pristup kameri je potreban za snimanje uporednih fotografija"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Доступ до камери потрібен, щоб робити фото порівняння"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Taqqoslash suratlarini olish uchun kameraga ruxsat kerak"
          }
        }
      }
    },
    "NSLocationWhenInUseUsageDescription": {
      "comment": "Privacy - Location When In Use Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Standort wird benötigt, um Fotos und Gemälde in Ihrer Nähe anzuzeigen"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Location is needed to show photos and paintings around you"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La ubicación es necesaria para mostrar fotos y pinturas a tu alrededor"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "La localisation est nécessaire pour afficher les photos et peintures autour de vous"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Жергілікті орын сіздің айналаңыздағы фотосуреттер мен картиналарды көрсету үшін қажет"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Геолокация нужна чтобы показывать фотографии и картины рядом с вами"
          }
        },
        "sr-Latn": {
          "stringUnit": {
            "state": "translated",
            "value": "Lokacija je potrebna za prikaz fotografija i slika u vašoj blizini"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Геолокація потрібна, щоб показувати фотографії та картини поблизу вас"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Joylashuv atrofingizdagi fotosuratlar va rasmlarni ko'rsatish uchun kerak"
          }
        }
      }
    },
    "NSPhotoLibraryAddUsageDescription": {
      "comment": "Privacy - Photo Library Additions Usage Description",
      "extractionState": "extracted_with_value",
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Die App benötigt diesen Zugriff, um Bilder in Ihrer Mediathek zu speichern"
          }
        },
        "en": {
          "stringUnit": {
            "state": "new",
            "value": "App needs this access to save images to your library"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "La aplicación necesita este acceso para guardar imágenes en tu biblioteca"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "L'application a besoin de cet accès pour enregistrer des images dans votre bibliothèque"
          }
        },
        "kk": {
          "stringUnit": {
            "state": "translated",
            "value": "Қолданбаға суреттерді галереяға сақтау үшін бұл рұқсат қажет"
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Приложению нужен доступ чтобы сохранить изображения в галерею"
          }
        },
        "sr-Latn": {
          "stringUnit": {
            "state": "translated",
            "value": "Aplikaciji je potreban ovaj pristup da bi sačuvala slike u vašu galeriju"
          }
        },
        "uk": {
          "stringUnit": {
            "state": "translated",
            "value": "Застосунку потрібен цей доступ, щоб зберігати зображення у вашу галерею"
          }
        },
        "uz": {
          "stringUnit": {
            "state": "translated",
            "value": "Ilova rasmlarni galereyangizdagi saqlash uchun ushbu ruxsat kerak"
          }
        }
      }
    }
  },
  "version": "1.0"
